# MongoDB Atlas connection string
MONGODB_URI=

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# AES server-only key (for DB at-rest encryption) — must be 32+ chars, NEVER expose to client
AES_SECRET_KEY=

# AES shared key (for E2E request/response encryption) — safe to expose to browser
NEXT_PUBLIC_AES_KEY=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
